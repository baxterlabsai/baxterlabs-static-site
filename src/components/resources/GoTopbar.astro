---
// Minimal-chrome topbar for /go outreach routes.
// Mirrors the main site Header's logo + CTA treatment so /go reads as
// part of baxterlabs.ai. No nav links (outreach-only surface).
---
<header class="go-chrome w-full">
  <div class="flex justify-between items-center px-6 md:px-12 py-4 max-w-full mx-auto">
    <a href="/" class="flex items-center">
      <img
        alt="BaxterLabs Logo"
        class="h-[83px] w-auto object-contain"
        src="/images/baxterlabs-logo.png"
      />
    </a>
    <a
      href="https://calendly.com/george-baxterlabs/30min"
      class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-6 py-3 rounded-sm font-label text-sm uppercase tracking-wider font-bold shadow-sm active:scale-95 transition-all"
    >
      Book a call
    </a>
  </div>
</header>
