---
import LeadCaptureForm from './LeadCaptureForm.astro'

interface Props {
  preselect?: 'guide' | 'assess' | null
  basePath?: string
}
const { preselect = null, basePath = '/resources' } = Astro.props
---
<main class="rp-page rp-wide" data-chooser data-preselect={preselect ?? ''} data-base-path={basePath}>

  <header class="hub-head">
    <div>
      <div class="rp-eyebrow-row">
        <span class="rp-eyebrow-rule"></span>
        <span class="rp-eyebrow-txt">Free Resources &middot; For Managing Partners</span>
      </div>
      <h1 class="rp-display">Two ways to see<br/>what your <span class="roman">P&amp;L</span> won't.</h1>
    </div>
    <div>
      <p class="rp-deck">
        Most $5M&ndash;$50M professional service firms are losing between <em>$200K and $1M a year</em>
        to five ordinary patterns that don't show up on the income statement. Start with either. They're designed to be read in one sitting.
      </p>
    </div>
  </header>

  <div class="hub-split" role="radiogroup" aria-label="Choose a resource">

    <div class="hub-panel" data-panel="guide" role="radio" aria-checked="false" tabindex="0">
      <div class="hub-panel-top">
        <div>
          <span class="hub-panel-mk">Field guide &middot; PDF &amp; Web</span>
          <div style="height: 0.75rem"></div>
          <div class="hub-toc" aria-hidden="true">
            <div class="ln"><span class="num">I</span><span>Payroll Drift</span><span class="pg">$80K&ndash;$300K</span></div>
            <div class="ln"><span class="num">II</span><span>Vendor Sprawl</span><span class="pg">$60K&ndash;$200K</span></div>
            <div class="ln"><span class="num">III</span><span>Billing Lag</span><span class="pg">$50K&ndash;$250K</span></div>
            <div class="ln"><span class="num">IV</span><span>Software Redundancy</span><span class="pg">$30K&ndash;$120K</span></div>
            <div class="ln"><span class="num">V</span><span>Approval Bottlenecks</span><span class="pg">$40K&ndash;$200K</span></div>
          </div>
        </div>
        <span class="hub-panel-num">01</span>
      </div>

      <h2 class="hub-h2">The <span class="roman">5</span> Profit Leaks<br/>Hiding in Every Firm</h2>
      <p class="hub-desc">A field guide for owners and managing partners. Five categories, five real engagements, five diagnostic questions. The mechanism before anyone hires anyone to fix it.</p>

      <div class="hub-time">12 minutes, coffee in hand</div>

      <div class="hub-outcome">
        <span class="hub-outcome-label">In this guide</span>5 categories &middot; 5 real-engagement examples &middot; 5 diagnostic questions
      </div>

      <div class="hub-cta-row">
        <span class="hub-radio" aria-hidden="true"></span>
        <span class="hub-radio-lbl">Get the guide</span>
      </div>
    </div>

    <div class="hub-panel is-cream" data-panel="assess" role="radio" aria-checked="false" tabindex="0">
      <div class="hub-panel-top">
        <div>
          <span class="hub-panel-mk">Self-assessment &middot; Interactive</span>
          <div style="height: 0.75rem"></div>
          <div class="hub-pips" aria-hidden="true">
            <span class="hub-pip is-filled"></span>
            <span class="hub-pip is-filled"></span>
            <span class="hub-pip is-filled"></span>
            <span class="hub-pip is-filled"></span>
            <span class="hub-pip is-filled"></span>
            <span class="hub-pip is-filled"></span>
            <span class="hub-pip is-filled"></span>
            <span class="hub-pip is-filled"></span>
            <span class="hub-pip"></span>
            <span class="hub-pip"></span>
            <span class="hub-pip"></span>
            <span class="hub-pip"></span>
            <span class="hub-pip-lbl">12 questions</span>
          </div>
        </div>
        <span class="hub-panel-num">02</span>
      </div>

      <h2 class="hub-h2">The Profit Leak<br/>Self-Assessment</h2>
      <p class="hub-desc">Twelve questions, a five-point honesty scale. You'll get a band, an exposure range in dollars, and a specific interpretation written for firms your size.</p>

      <div class="hub-time">4 minutes, honest answers</div>

      <div class="hub-outcome">
        <span class="hub-outcome-label">Typical reader</span>finds $180K&ndash;$520K in annual exposure
      </div>

      <div class="hub-cta-row">
        <span class="hub-radio" aria-hidden="true"></span>
        <span class="hub-radio-lbl">Start the assessment</span>
      </div>
    </div>
  </div>

  <section class="capture-card" data-capture>
    <div class="capture-head">
      <div class="kicker">A quick intro first</div>
      <div class="capture-title" data-capture-title>Who's reading?</div>
      <p class="capture-sub" data-capture-sub>
        A few details, then the guide opens.
      </p>
    </div>

    <div data-capture-body>
      <LeadCaptureForm formId="hub-capture" asset="field_guide" submitLabel="Unlock" />
    </div>
  </section>

  <section class="success-card" data-success aria-live="polite">
    <div class="kicker">Unlocked</div>
    <div class="success-title" data-success-title>The guide is ready.</div>
    <p class="success-body" data-success-body>Open the web version below, or download the printable PDF. Either works.</p>
    <div class="success-actions" data-success-actions>
      <a class="rp-btn" data-success-primary href={`${basePath}/five-profit-leaks/read`}>Open the web version <span class="arrow">&rarr;</span></a>
      <a class="rp-btn is-ghost" data-success-secondary href="/resources/BaxterLabs_Lead_Magnet_01_Five_Profit_Leaks.pdf">Download the PDF <span class="arrow">&rarr;</span></a>
    </div>
  </section>
</main>

<script>
  import type { RevenueRange, LeadMagnetAsset } from '../../lib/supabase'

  type Which = 'guide' | 'assess' | null

  // Writes go through the backend /api/lead-capture endpoint so field_guide
  // submissions can be dual-written into lead_magnet_captures + enrolled in
  // the Profit Leaks nurture sequence atomically. See Session 1 handoff.
  const API_URL: string = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000'

  const root = document.querySelector<HTMLElement>('[data-chooser]')
  if (!root) throw new Error('chooser root missing')
  const basePath = (root.dataset.basePath || '/resources').replace(/\/$/, '')

  const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-panel]'))
  const captureTitle = root.querySelector<HTMLElement>('[data-capture-title]')
  const captureSub = root.querySelector<HTMLElement>('[data-capture-sub]')
  const captureCard = root.querySelector<HTMLElement>('[data-capture]')
  const successCard = root.querySelector<HTMLElement>('[data-success]')
  const successTitle = root.querySelector<HTMLElement>('[data-success-title]')
  const successBody = root.querySelector<HTMLElement>('[data-success-body]')
  const successPrimary = root.querySelector<HTMLAnchorElement>('[data-success-primary]')
  const successSecondary = root.querySelector<HTMLAnchorElement>('[data-success-secondary]')
  const form = root.querySelector<HTMLFormElement>('form#hub-capture')
  const errorEl = form?.querySelector<HTMLElement>('[data-error]')
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]')
  const promiseEl = form?.querySelector<HTMLElement>('[data-capture-promise]')

  const GUIDE_TITLE = "Who's reading?"
  const GUIDE_SUB = 'A few details, then the guide opens.'
  const ASSESS_TITLE = "Who's taking this?"
  const ASSESS_SUB = "A few details, then the <span class=\"roman\">12</span> questions. You'll see your results on this page."

  const GUIDE_PROMISE = "Prefer a number over a read? The 4-minute assessment is right above."
  const ASSESS_PROMISE = "No drip sequence. No follow-ups you didn't ask for. Straight to your results."

  let selected: Which = null

  function select(which: Which) {
    selected = which
    const assess = which === 'assess'
    for (const p of panels) {
      const isSel = p.dataset.panel === which
      p.classList.toggle('is-selected', isSel)
      p.setAttribute('aria-checked', String(isSel))
    }
    if (!captureTitle || !captureSub) return

    if (assess) {
      captureTitle.textContent = ASSESS_TITLE
      captureSub.innerHTML = ASSESS_SUB
      if (promiseEl) promiseEl.textContent = ASSESS_PROMISE
    } else {
      captureTitle.textContent = GUIDE_TITLE
      captureSub.innerHTML = GUIDE_SUB
      if (promiseEl) promiseEl.textContent = GUIDE_PROMISE
    }
  }

  for (const p of panels) {
    p.addEventListener('click', () => select(p.dataset.panel as Which))
    p.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        select(p.dataset.panel as Which)
      }
    })
  }

  // Initial selection: data-preselect attr wins, then ?asset= query, else 'guide'
  const params = new URLSearchParams(location.search)
  const attrPre = (root.dataset.preselect || '').trim() || null
  const queryPre = params.get('asset')
  const initial: Which = (attrPre === 'guide' || attrPre === 'assess')
    ? attrPre
    : (queryPre === 'guide' || queryPre === 'assess')
      ? queryPre
      : 'guide'
  select(initial)

  function configureSuccess(asset: LeadMagnetAsset) {
    if (asset === 'self_assessment') {
      if (successTitle) successTitle.textContent = 'Unlocked. Ready when you are.'
      if (successBody) successBody.textContent = 'Start the twelve questions below. You’ll see your band, exposure range, and a written interpretation as soon as you finish.'
      if (successPrimary) {
        successPrimary.href = `${basePath}/self-assessment/take`
        successPrimary.innerHTML = 'Take the assessment <span class="arrow">&rarr;</span>'
      }
      if (successSecondary) {
        successSecondary.href = `${basePath}/five-profit-leaks/read`
        successSecondary.innerHTML = 'Read the field guide <span class="arrow">&rarr;</span>'
      }
    } else {
      if (successTitle) successTitle.textContent = 'The guide is ready.'
      if (successBody) successBody.textContent = 'Open the web version below, or download the printable PDF. Either works.'
      if (successPrimary) {
        successPrimary.href = `${basePath}/five-profit-leaks/read`
        successPrimary.innerHTML = 'Open the web version <span class="arrow">&rarr;</span>'
      }
      if (successSecondary) {
        // PDF lives at /resources/... regardless of surface — it's a public asset, not a route
        successSecondary.href = '/resources/BaxterLabs_Lead_Magnet_01_Five_Profit_Leaks.pdf'
        successSecondary.innerHTML = 'Download the PDF <span class="arrow">&rarr;</span>'
      }
    }
  }

  function errorMessageFor(status: number): string {
    if (status === 429) return "Too many submissions from this location. Please try again in a few minutes."
    if (status === 400) return "Please check your details and try again."
    return "Something went wrong saving that. Try again, or email george@baxterlabs.ai directly."
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!form.checkValidity()) { form.reportValidity(); return }
    if (errorEl) { errorEl.classList.remove('visible'); errorEl.textContent = '' }

    const fd = new FormData(form)
    const name = String(fd.get('name') ?? '').trim()
    const email = String(fd.get('email') ?? '').trim()
    const firm = String(fd.get('firm') ?? '').trim()
    const revenue = String(fd.get('revenue') ?? '').trim() as RevenueRange | ''
    const role = String(fd.get('role') ?? '').trim()
    // Honeypot — humans never see/reach this field. Pass-through to the
    // backend, which silently drops the request if it's non-empty.
    const honeypot = String(fd.get('website_url') ?? '')

    if (!name || !email || !firm || !revenue) {
      form.reportValidity()
      return
    }

    const asset: LeadMagnetAsset = selected === 'assess' ? 'self_assessment' : 'field_guide'

    if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.6' }
    try {
      const res = await fetch(`${API_URL}/api/lead-capture`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          asset,
          name,
          email,
          company_name: firm,
          revenue_range: revenue,
          role: role || null,
          source_url: window.location.href,
          website_url: honeypot,
        }),
      })

      if (!res.ok) {
        throw Object.assign(new Error(`lead-capture ${res.status}`), { status: res.status })
      }

      const data = await res.json().catch(() => ({}))
      // 'captured' and 'already_subscribed' both reveal the unlock UI —
      // the visitor already gets the guide regardless of dedupe status.
      if (data.status !== 'captured' && data.status !== 'already_subscribed') {
        throw new Error(`unexpected status: ${data.status}`)
      }

      configureSuccess(asset)
      captureCard?.style.setProperty('display', 'none')
      successCard?.classList.add('visible')
      if (successCard) {
        const y = successCard.getBoundingClientRect().top + window.scrollY - 130
        window.scrollTo({ top: y, behavior: 'smooth' })
      }
    } catch (err) {
      const status = (err as { status?: number })?.status ?? 0
      if (errorEl) {
        errorEl.textContent = errorMessageFor(status)
        errorEl.classList.add('visible')
      }
      console.error('[lead-capture]', err)
      if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = '' }
    }
  })
</script>
