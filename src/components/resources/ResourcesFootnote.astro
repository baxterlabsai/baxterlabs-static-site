---
interface Props {
  left?: string
  rightHref?: string
  rightLabel?: string
}
const { left, rightHref, rightLabel } = Astro.props
---
<div class="rp-footnote">
  <div>{left ?? ''}</div>
  <div class="rp-brand-mk">BaxterLabs Advisory</div>
  <div>
    {rightHref && rightLabel
      ? <a href={rightHref} style="color:var(--bl-teal); text-decoration:none;">{rightLabel}</a>
      : (rightLabel ?? 'George DeVries · Alfonso Cordon')}
  </div>
</div>
