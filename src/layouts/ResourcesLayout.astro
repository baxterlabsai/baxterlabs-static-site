---
import BaseLayout from './BaseLayout.astro'
import '../styles/resources.css'

interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
}

const { title, description, canonical, ogImage } = Astro.props
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
>
  <slot />
</BaseLayout>
