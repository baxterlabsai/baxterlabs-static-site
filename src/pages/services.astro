---
import BaseLayout from '../layouts/BaseLayout.astro'
import '../components/services/services.css'
import '../components/homepage/leak-meter.css'
import ExecutiveSummaryLightbox from '../components/islands/ExecutiveSummaryLightbox'
import ServicesTimeline from '../components/services/ServicesTimeline'
import ServicesTierCalibrator from '../components/services/ServicesTierCalibrator'
import LeakMeter from '../components/homepage/LeakMeter'

const title = 'BaxterLabs Advisory | The 14-Day Profit Leak Diagnostic | $12,500 Fixed'
const description = 'A 14-day forensic diagnostic for professional service firms with $5M to $50M in annual revenue. Fixed price, $12,500. Six executive-ready deliverables including a full diagnostic report, quantification workbook, and implementation roadmap. The 14-day clock starts after stakeholder interviews complete.'
const canonical = 'https://baxterlabs.ai/services'

// TODO: replace with dark-dossier share card (1200x630). Using the
// default site OG as a placeholder until design delivers the asset.
const ogImage = '/images/baxterlabs-og.png'

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://baxterlabs.ai/#org',
  name: 'BaxterLabs Advisory',
  url: 'https://baxterlabs.ai/',
}

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://baxterlabs.ai/services#service',
  name: 'Profit Leak Diagnostic',
  serviceType: '14-day forensic profit diagnostic',
  provider: { '@id': 'https://baxterlabs.ai/#org' },
  areaServed: 'United States professional service firms, $5M-$50M revenue range',
  offers: {
    '@type': 'Offer',
    price: '12500',
    priceCurrency: 'USD',
    description: '14-day fixed-scope diagnostic, clock begins after last stakeholder interview',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Diagnostic Deliverables',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Executive Summary' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Full Diagnostic Report' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Implementation Roadmap' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Profit Leak Quantification Workbook' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Executive Presentation Deck' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Retainer Proposal (optional)' } },
    ],
  },
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://baxterlabs.ai/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://baxterlabs.ai/services' },
  ],
}
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="website"
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <div class="sv-page">

    {/* SECTION 1 — HERO + PROMOTED PREVIEW */}
    <section class="sv-hero" data-screen-label="01 Hero">
      <div class="sv-hero-grid"></div>
      <div class="sv-hero-inner">
        <div>
          <div class="sv-hero-eyebrow">BaxterLabs Advisory</div>
          <h1>
            <span class="roman">Fourteen days from</span>
            <span class="crimson">last interview</span>
            <span class="roman">to final findings.</span>
          </h1>
          <p class="sv-hero-sub">
            A rigorous forensic diagnostic for professional service firms with <strong>$5M to $50M</strong> in annual revenue. Fixed scope, fixed price, <strong>$12,500</strong>. We identify where margin is leaking, quantify each leak in dollars, and deliver a prioritized roadmap your team can execute without us.
          </p>
          <div class="sv-hero-cta">
            <a href="/get-started" class="sv-btn">Start Your Diagnostic <span class="arrow">&rarr;</span></a>
            <button type="button" class="sv-hero-cta-secondary" data-open-executive-summary>
              View Sample Executive Summary &rarr;
            </button>
          </div>
          <span class="sv-nda">A mutual confidentiality agreement (NDA) is executed prior to any data intake.</span>
        </div>

        <button type="button" class="sv-sample-tile" data-open-executive-summary aria-label="View sample executive summary">
          <div class="sv-sample-head">
            <span>Sample Deliverable &middot; 01 of 06</span>
            <span class="dot"></span>
          </div>
          <div class="sv-sample-body sv-sample-preview">
            <div class="sv-sample-preview-hover" aria-hidden="true">
              <span class="sv-sample-preview-pill">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
                Preview Document
              </span>
            </div>
            <div class="sv-sample-preview-title">
              <img src="/images/baxterlabs-logo.png" alt="" class="sv-sample-preview-logo" />
              <p class="sv-sample-preview-eyebrow">BaxterLabs Advisory</p>
              <h3 class="sv-sample-preview-h1">Executive Summary</h3>
              <p class="sv-sample-preview-subtitle">Profit Leak &amp; Operational Efficiency Diagnostic</p>
              <div class="sv-sample-preview-rule"></div>
              <p class="sv-sample-preview-prepared">Prepared for</p>
              <p class="sv-sample-preview-firm">Regional Staffing Firm (Illustrative Example)</p>
            </div>
            <div class="sv-sample-preview-finding">
              <p class="sv-sample-preview-heading">Headline Finding</p>
              <div class="sv-sample-preview-box">
                <p>BaxterLabs Advisory has identified <strong>$2,784,000</strong> to <strong>$4,384,000</strong> in annual profit leak opportunity across the Firm, with a moderate estimate of <strong>$3,585,000</strong>.</p>
              </div>
            </div>
            <div class="sv-sample-preview-chart">
              <img src="/images/sample-deliverables/exec-summary/chart-profit-leak-by-category.png" alt="" />
            </div>
            <div class="sv-sample-preview-fade" aria-hidden="true"></div>
          </div>
          <div class="sv-sample-footer">
            <span class="cta">View Sample &rarr;</span>
            <span class="meta">PDF &middot; 14 pages</span>
          </div>
        </button>
      </div>
    </section>

    {/* SECTION 2 — THE 14-DAY TIMELINE */}
    <section class="sv-section sv-section--white" data-screen-label="02 The 14-Day Timeline">
      <div class="sv-inner">
        <div class="sv-eyebrow"><span class="line"></span><span class="txt">02 &middot; The Engagement</span></div>
        <h2 class="sv-h2">How the engagement <span class="roman">actually runs.</span></h2>
        <div class="sv-body sv-narrow" style="margin-left: 0;">
          <p>We don't run an open-ended discovery process. We run a procedure. Here is what happens, day by day, and where your team's time is actually needed.</p>
        </div>

        <ServicesTimeline client:visible />

        <div class="sv-body sv-narrow" style="margin-left: 0; margin-top: 2.5rem;">
          <p>The clock not starting until the last interview is complete means the timeline we promise is a timeline we control. Most consulting engagements promise a delivery date and then blame you when it slips. <strong>We promise fourteen days from a moment we can actually measure.</strong></p>
        </div>
      </div>
    </section>

    {/* SECTION 3 — DELIVERABLES */}
    <section class="sv-section" data-screen-label="03 Deliverables">
      <div class="sv-inner">
        <div class="sv-eyebrow"><span class="line"></span><span class="txt">03 &middot; What You Get</span></div>
        <h2 class="sv-h2">Six deliverables. <span class="roman">Executive-ready. No scope creep.</span></h2>
        <div class="sv-body sv-narrow" style="margin-left: 0;">
          <p>Every engagement produces the same six artifacts. Each one is positioned for a specific decision or conversation.</p>
        </div>

        <div class="sv-dx">
          <article class="sv-dx-card">
            <div class="n"><span>01</span><span class="tag">For the board</span></div>
            <h4>Executive Summary</h4>
            <p class="desc">A board-ready overview of findings, risk exposure, and priority recovery actions.</p>
            <p class="use"><em>Use it to drive the decision conversation with partners and the board.</em></p>
          </article>
          <article class="sv-dx-card">
            <div class="n"><span>02</span><span class="tag">For your team</span></div>
            <h4>Full Diagnostic Report</h4>
            <p class="desc">Complete analysis of every identified profit leak with root-cause identification and quantified P&amp;L impact.</p>
            <p class="use"><em>Use it when your team needs to address the actual problem, not the visible symptom.</em></p>
          </article>
          <article class="sv-dx-card">
            <div class="n"><span>03</span><span class="tag">For execution</span></div>
            <h4>Implementation Roadmap</h4>
            <p class="desc">A prioritized 90-day action plan sequenced by impact and tied directly to findings.</p>
            <p class="use"><em>Use it to turn analysis into execution without external dependencies.</em></p>
          </article>
          <article class="sv-dx-card">
            <div class="n"><span>04</span><span class="tag">For the finance team</span></div>
            <h4>Profit Leak Quantification Workbook</h4>
            <p class="desc">The underlying financial model showing exactly where margin is eroding and the recovery potential per category.</p>
            <p class="use"><em>Use it to prioritize fixes by actual dollar value rather than intuition.</em></p>
          </article>
          <article class="sv-dx-card">
            <div class="n"><span>05</span><span class="tag">For stakeholders</span></div>
            <h4>Executive Presentation Deck</h4>
            <p class="desc">A structured slide deck summarizing findings, priorities, and recommended actions for stakeholder alignment.</p>
            <p class="use"><em>Use it to present the diagnostic to the board, partners, or leadership teams.</em></p>
          </article>
          <article class="sv-dx-card optional">
            <div class="n"><span>06</span><span class="tag">Optional</span></div>
            <h4>Retainer Proposal</h4>
            <p class="desc">A scoped proposal for ongoing advisory and implementation support. Ships with every diagnostic; accepting it is optional.</p>
            <p class="use"><em>This is not part of the diagnostic pricing. Decline it and the diagnostic still includes everything above.</em></p>
          </article>
        </div>

        <p class="sv-dx-close">Every finding in every deliverable is cited back to the source data. <strong>If you disagree with a finding, we walk through the math together.</strong></p>
      </div>
    </section>

    {/* SECTION 4 — THE ARITHMETIC */}
    <section class="sv-section sv-section--white" data-screen-label="04 The Arithmetic">
      <div class="sv-inner">
        <div class="sv-eyebrow"><span class="line"></span><span class="txt">04 &middot; The Arithmetic</span></div>
        <h2 class="sv-h2">The math at <span class="roman">your firm size.</span></h2>
        <div class="sv-body sv-narrow" style="margin-left: 0;">
          <p>The diagnostic is <strong>$12,500</strong>. Fixed. Paid once. Here is what that typically recovers, calibrated to your firm's revenue range.</p>
        </div>

        <ServicesTierCalibrator client:visible />

        <div class="sv-body sv-narrow" style="margin-left: 0; margin-top: 2.5rem;">
          <p>At every firm size in our range, the diagnostic <strong>pays for itself at the floor</strong> of the recovery range. The question is not whether the math works. <em>The question is why most firms have not run one yet.</em></p>
          <p>For the full walkthrough of the five leak categories and a $3.585M anonymized case study, read our <a href="/profit-leaks">Profit Leaks analysis &rarr;</a></p>
        </div>
      </div>
    </section>

    {/* SECTION 5 — COMPARISON */}
    <section class="sv-section" data-screen-label="05 Comparison Matrix">
      <div class="sv-inner">
        <div class="sv-eyebrow"><span class="line"></span><span class="txt">05 &middot; The Alternatives</span></div>
        <h2 class="sv-h2">How this compares <span class="roman">to the alternatives.</span></h2>
        <div class="sv-body sv-narrow" style="margin-left: 0;">
          <p>There are three other things a firm your size might do instead of running this diagnostic. Here is how they compare on the dimensions that matter.</p>
        </div>

        <div class="sv-cx">
          <table class="sv-cx-table">
            <thead>
              <tr>
                <th class="dim">Dimension</th>
                <th>Traditional Consulting</th>
                <th>Software Dashboard</th>
                <th>Fractional CFO</th>
                <th class="bl">BaxterLabs Diagnostic</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="dim">Cost</td>
                <td>$200K &ndash; $500K+</td>
                <td>$15K &ndash; $50K / year</td>
                <td>$5K &ndash; $15K / month ongoing</td>
                <td class="bl"><strong>$12,500 fixed, once</strong></td>
              </tr>
              <tr>
                <td class="dim">Timeline</td>
                <td>3 &ndash; 6 months</td>
                <td>Ongoing (data only)</td>
                <td>Ongoing (no endpoint)</td>
                <td class="bl"><strong>14 days from last interview</strong></td>
              </tr>
              <tr>
                <td class="dim">Who delivers</td>
                <td>Partner-sold, associate-staffed</td>
                <td>Software (no interpretation)</td>
                <td>One person, generalist</td>
                <td class="bl"><strong>Partners only, 25 years P&amp;L ownership</strong></td>
              </tr>
              <tr>
                <td class="dim">What you get</td>
                <td>Strategic recommendations</td>
                <td>Dashboards and data</td>
                <td>Ongoing finance support</td>
                <td class="bl"><strong>Quantified findings with source citations, prioritized roadmap</strong></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="sv-body sv-narrow" style="margin-left: 0; margin-top: 2rem;">
          <p>Traditional consulting is excellent for strategy transformations at $200M+ firms. It was never designed for what $5M to $50M firms need. Software dashboards are good at displaying the numbers and bad at interpreting them. Fractional CFOs solve a real problem but not this one; they provide ongoing finance support, not a forensic diagnostic with an endpoint. <strong>The BaxterLabs Diagnostic was built specifically for the gap in the middle.</strong></p>
        </div>
      </div>
    </section>

    {/* SECTION 6 — DATA HANDLING */}
    <section class="sv-section sv-section--white" data-screen-label="06 Data Handling">
      <div class="sv-inner">
        <div class="sv-eyebrow"><span class="line"></span><span class="txt">06 &middot; Confidentiality</span></div>
        <h2 class="sv-h2">How we handle <span class="roman">your financial data.</span></h2>
        <div class="sv-body sv-narrow" style="margin-left: 0;">
          <p>All engagements operate under strict confidentiality. Client data is handled through a controlled, access-managed workflow designed for sensitive financial information.</p>
        </div>

        <div class="sv-pi">
          <article class="sv-pi-card">
            <div class="sv-pi-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3L4 6v6c0 5 3.5 8 8 9 4.5-1 8-4 8-9V6l-8-3z"/></svg>
            </div>
            <h5>Mutual NDA</h5>
            <p>Executed before any data is exchanged. Standard non-disclosure, both directions.</p>
          </article>
          <article class="sv-pi-card">
            <div class="sv-pi-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="5" y="11" width="14" height="10" rx="1"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>
            </div>
            <h5>Encrypted &amp; Access-Controlled</h5>
            <p>All client data encrypted in transit and at rest. Access restricted to the partner team and the specific engagement.</p>
          </article>
          <article class="sv-pi-card">
            <div class="sv-pi-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M5.5 5.5l13 13"/></svg>
            </div>
            <h5>No External Use</h5>
            <p>Your data is never aggregated, shared with third parties, or used outside the scope of your engagement. Confidential handling is non-negotiable.</p>
          </article>
          <article class="sv-pi-card">
            <div class="sv-pi-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M7 3h7l5 5v13H7V3z"/><path d="M14 3v6h6"/><path d="M10 15l4-4M10 11l4 4"/></svg>
            </div>
            <h5>Destruction Protocol</h5>
            <p>At the end of the engagement, you can choose full secure return or verified destruction of all datasets. Default is destruction at 30 days post-delivery unless you request retention.</p>
          </article>
        </div>
      </div>
    </section>

    {/* SECTION 7 — FINAL CTA */}
    <section class="sv-section sv-final" data-screen-label="07 Final CTA">
      <div class="sv-inner sv-narrow">
        <div class="sv-eyebrow"><span class="line"></span><span class="txt">07 &middot; Start Your Diagnostic</span></div>
        <h2 class="sv-h2" style="text-align: center;">Start your <span class="roman">diagnostic.</span></h2>
        <div class="sv-body">
          <p>Stop the bleed. Quantify the recovery. <strong>Selective client intake; we take a limited number of engagements per quarter to protect delivery quality.</strong></p>
        </div>
        <div style="margin-top: 2.5rem;">
          <a href="/get-started" class="sv-btn is-cream">Start Your Diagnostic <span class="arrow">&rarr;</span></a>
        </div>
        <span class="sv-nda">Consultation for revenue $5M &ndash; $50M &middot; A mutual confidentiality agreement (NDA) is executed prior to any data intake.</span>
        <div class="sv-body" style="margin-top: 2rem; font-size: 0.95rem;">
          <p>Want to read the full methodology first? <a href="/profit-leaks">Read the Profit Leaks analysis &rarr;</a></p>
        </div>
      </div>
    </section>

    {/* Executive Summary lightbox — listens for 'open-executive-summary'
        events dispatched by the [data-open-executive-summary] buttons
        below. client:idle so it mounts after the page is interactive. */}
    <ExecutiveSummaryLightbox client:idle />

    {/* Leak Meter — pinned interactive. Same mount pattern as the
        homepage. Dismissed state persists via localStorage; a visitor
        who dismissed the meter on / arrives on /services with it still
        dismissed. Tier state syncs with ServicesTierCalibrator via the
        bl:tierchange custom event. */}
    <LeakMeter client:load />
  </div>
</BaseLayout>

<script>
  // Wire every [data-open-executive-summary] trigger (hero tile + hero
  // secondary link) to the existing lightbox island's open event.
  document.querySelectorAll<HTMLElement>('[data-open-executive-summary]').forEach((el) => {
    el.addEventListener('click', () => {
      window.dispatchEvent(new Event('open-executive-summary'))
    })
  })
</script>
