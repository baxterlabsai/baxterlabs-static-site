---
import BaseLayout from '../layouts/BaseLayout.astro'
import '../components/homepage/home.css'
import LeakMeter from '../components/homepage/LeakMeter'
import BreakEvenVisualizer from '../components/homepage/BreakEvenVisualizer'

const title = 'Profit Leak Diagnostic for $5M-$50M Firms | BaxterLabs Advisory'
const description = 'You feel it in the quarterly review: the number is not what it should be. BaxterLabs runs a 14-day forensic diagnostic for $5M to $50M professional service firms. Fixed price, $12,500, typical finding pays for itself 16 to 80 times over.'
const canonical = 'https://baxterlabs.ai/'

// TODO: replace with custom dark-dossier share card (1200x630).
// Using the default site OG as a placeholder until design delivers the asset.
const ogImage = '/images/baxterlabs-og.png'

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://baxterlabs.ai/#org',
  name: 'BaxterLabs Advisory',
  url: 'https://baxterlabs.ai/',
  description: 'Profit leak diagnostic for $5M to $50M professional service firms.',
  founder: { '@type': 'Person', name: 'George DeVries', jobTitle: 'Managing Partner' },
}

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://baxterlabs.ai/#service',
  name: 'Profit Leak Diagnostic',
  provider: { '@id': 'https://baxterlabs.ai/#org' },
  serviceType: 'Forensic profit diagnostic',
  areaServed: 'United States professional service firms, $5M-$50M revenue range',
  offers: {
    '@type': 'Offer',
    price: '12500',
    priceCurrency: 'USD',
    description: '14-day fixed-scope diagnostic',
  },
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://baxterlabs.ai/' },
  ],
}
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="website"
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <div class="hp-page">

    {/* SECTION 1 — HERO */}
    <section class="hp-hero" data-screen-label="01 Hero">
      <div class="hp-hero-grid"></div>
      <div class="hp-hero-bg"></div>
      <div class="hp-hero-inner">
        <div class="hp-hero-eyebrow">BaxterLabs Advisory</div>
        <h1 class="hp-hero-h1">
          <span class="roman">You feel it in the</span> <span class="crimson">quarterly review.</span>
        </h1>
        <p class="hp-hero-sub">
          Revenue is growing. Headcount is growing. But the number at the bottom is not what it should be, and you cannot say exactly why. For professional service firms in the <strong>$5M to $50M range</strong>, that feeling is almost always right, and the gap between what your margin should be and what it is typically adds up to <strong>between 5 and 15 percent of EBITDA</strong>. This page shows you what that looks like in dollars per minute, what the diagnostic costs against what it typically finds, and what to do next if the numbers make you want to move.
        </p>
        <div class="hp-hero-cta">
          <a href="/get-started" class="hp-btn">Start Your Diagnostic <span class="arrow">→</span></a>
          <a href="/profit-leaks" class="hp-btn is-ghost">Read the Full Analysis <span class="arrow">→</span></a>
        </div>
        <span class="hp-nda">A mutual confidentiality agreement (NDA) is executed prior to any data intake.</span>
      </div>
    </section>

    {/* SECTION 2 — THE FEELING */}
    <section class="hp-section hp-section--white" data-screen-label="02 The Feeling">
      <div class="hp-inner hp-narrow">
        <div class="hp-eyebrow"><span class="line"></span><span class="txt">02 &middot; The Feeling</span></div>
        <h2 class="hp-h2">You already know <span class="roman">something is off.</span></h2>
        <div class="hp-body">
          <p>If you are running a professional service firm and revenue is growing but profit does not feel like it is keeping pace, you are not imagining it.</p>
          <p>We keep hearing the same thing from managing partners in your range. Revenue is up 15, 20, sometimes 30 percent year over year. The team is bigger. The pipeline is full. But the cash in the bank at the end of the quarter does not feel right. Something is leaking, and the P&amp;L is not telling you where.</p>
          <p><em>Do you feel that too?</em></p>
          <p>If you do, the instinct is almost always right. That is the feeling this firm was built to address.</p>
        </div>
      </div>
    </section>

    {/* SECTION 3 — METER EXPLAINER */}
    <section class="hp-section" data-screen-label="03 Meter Explainer">
      <div class="hp-inner hp-narrow">
        <div class="hp-eyebrow"><span class="line"></span><span class="txt">03 &middot; About the Meter</span></div>
        <h2 class="hp-h2" style="font-size: clamp(1.5rem, 2.2vw + 0.5rem, 2.25rem);">About the meter <span class="roman">in the corner.</span></h2>
        <div class="hp-body">
          <p>The meter running in the corner of this page is not a measurement of your firm. It is illustrative. It runs at the typical per-minute rate of recoverable profit for firms in the size range you selected, based on patterns from BaxterLabs diagnostic work.</p>
          <p>For firms in the <strong>$5M to $50M range</strong>, the right order of magnitude is somewhere between <strong>fifty cents and four dollars every minute</strong>. Across an unexamined quarter, that is real money. Across an unexamined year, it is the difference between a comfortable operating cushion and a technical covenant breach.</p>
          <p>The meter is running while you read. <em>If the number makes you uncomfortable, trust the discomfort.</em></p>
        </div>
      </div>
    </section>

    {/* SECTION 4 — BREAK-EVEN VISUALIZER */}
    <section class="hp-section hp-section--white" data-screen-label="04 Break-Even Visualizer">
      <div class="hp-inner">
        <div class="hp-eyebrow"><span class="line"></span><span class="txt">04 &middot; The Math, Briefly</span></div>
        <h2 class="hp-h2" style="max-width: 22ch;">The diagnostic is <span class="crimson">$12,500.</span> The finding is <span class="roman">many multiples.</span></h2>
        <div class="hp-body hp-narrow" style="margin-left: 0;">
          <p>That is the fixed price, paid once. The typical finding at firms your size recovers many multiples of that in annual profit. <strong>The math is worth pausing on.</strong></p>
        </div>

        <BreakEvenVisualizer client:visible />

        <div class="hp-body hp-narrow" style="margin-left: 0; margin-top: 2.5rem;">
          <p>At every firm size in our range, the diagnostic <strong>pays for itself at the floor</strong> of the recovery range. At the midpoint, the return multiples into territory where the question is no longer whether to do it but <em>why you waited</em>.</p>
        </div>
      </div>
    </section>

    {/* SECTION 5 — WHY BAXTERLABS */}
    <section class="hp-section" data-screen-label="05 Why BaxterLabs">
      <div class="hp-inner hp-narrow">
        <div class="hp-eyebrow"><span class="line"></span><span class="txt">05 &middot; Why BaxterLabs</span></div>
        <h2 class="hp-h2">Why <span class="roman">this firm</span> exists.</h2>
        <div class="hp-body">
          <p>We built BaxterLabs because we kept meeting managing partners who knew something was wrong but could not get a useful diagnostic. The tools available to them were either generic consulting engagements priced at six figures with multi-month timelines, or software dashboards that could display data but could not interpret it. Nothing in the middle was built to do what firms at your scale actually need.</p>
          <p>What firms in the $5M to $50M range need is a <strong>forensic look, delivered in two weeks, priced so the math is obvious</strong>, led by someone who has actually run a P&amp;L. That is what BaxterLabs does. The diagnostic is the output. The point of view is that growth without infrastructure is the real problem, and the five leak categories we diagnose are where that gap shows up in the numbers.</p>
          <p>The full point of view, with the 19-leak case study that produced $3.585M in findings at one recent engagement, lives on the <a href="/profit-leaks">Profit Leaks page</a>. That is the long version. The homepage is the short version.</p>
        </div>
      </div>
    </section>

    {/* SECTION 6 — THREE PATHS */}
    <section class="hp-section hp-section--white" data-screen-label="06 Three Paths">
      <div class="hp-inner">
        <div class="hp-eyebrow"><span class="line"></span><span class="txt">06 &middot; Three Paths</span></div>
        <h2 class="hp-h2">Three ways to <span class="roman">go from here.</span></h2>
        <div class="hp-body hp-narrow" style="margin-left: 0;">
          <p>Depending on where you are today, one of these three next steps fits.</p>
        </div>

        <div class="hp-paths">
          <article class="hp-path-card">
            <div class="kicker">01 &middot; Not Sure Yet</div>
            <h3>The 4-minute Profit Leak Self-Assessment.</h3>
            <p>Twelve questions, a scored result, and a specific interpretation written for firms your size. No email required to see your score.</p>
            <a href="/resources/self-assessment/take" class="hp-btn is-ghost">Take the Assessment <span class="arrow">→</span></a>
          </article>
          <article class="hp-path-card">
            <div class="kicker">02 &middot; Want the Full Thinking</div>
            <h3>Read the Profit Leaks pillar.</h3>
            <p>The five leak categories, the structural reason they exist, the fragility loop that compounds them, and an anonymized case with $3.585M in findings across 19 leaks.</p>
            <a href="/profit-leaks" class="hp-btn is-ghost">Read the Analysis <span class="arrow">→</span></a>
          </article>
          <article class="hp-path-card">
            <div class="kicker">03 &middot; Ready to Run One</div>
            <h3>Start a diagnostic.</h3>
            <p>14 days, $12,500, fixed scope. A mutual NDA is executed before any data intake. Two-week turnaround on the full findings report.</p>
            <a href="/get-started" class="hp-btn">Start Your Diagnostic <span class="arrow">→</span></a>
          </article>
        </div>
      </div>
    </section>

    {/* SECTION 7 — TRUST FRAME */}
    <section class="hp-section" data-screen-label="07 Trust Frame">
      <div class="hp-inner">
        <div class="hp-eyebrow"><span class="line"></span><span class="txt">07 &middot; Trust Frame</span></div>
        <h2 class="hp-h2">Led by partners. <span class="roman">Audited by you.</span></h2>
        <div class="hp-body hp-narrow" style="margin-left: 0;">
          <p>Every BaxterLabs engagement is led exclusively by partners with 25 years of real-world P&amp;L ownership. No junior analysts. No subcontractors. No learning on your time. The methodology is auditable end to end. Every finding includes the source data citation, the calculation methodology, and the specific line items that produced the number. <strong>If you disagree with a finding, we walk through the math together until we agree.</strong></p>
        </div>

        <div class="hp-trust-row">
          <div class="hp-trust-item"><strong>Mutual NDA</strong>executed before any data intake</div>
          <div class="hp-trust-item"><strong>100% auditable findings</strong>with source citations</div>
          <div class="hp-trust-item"><strong>Led by partners</strong>not junior staff or subcontractors</div>
          <div class="hp-trust-item"><strong>Fixed price, $12,500</strong>no scope creep, no change orders</div>
        </div>
      </div>
    </section>

    {/* SECTION 8 — FINAL CTA */}
    <section class="hp-section hp-final" data-screen-label="08 Final CTA">
      <div class="hp-inner hp-narrow">
        <div class="hp-eyebrow"><span class="line"></span><span class="txt">08 &middot; While You Were Here</span></div>
        <h2 class="hp-h2">While you were on this page, <span class="roman">your firm likely leaked.</span></h2>
        <div class="hp-body">
          <p>While you were on this page, your firm likely leaked <strong class="hp-final-num" id="final-leak">$0</strong>. That is illustrative, not measured. But it is the right order of magnitude. The diagnostic is $12,500. If the finding comes in at the floor of the range for firms your size, it pays for itself in <strong class="hp-final-num" id="final-days">about 28 days</strong>. At the midpoint, faster.</p>
          <p>The question is not whether your firm has leaks. The question is whether you want to know where they are before the next covenant test, the next acquisition conversation, or the next quarterly review.</p>
        </div>
        <div style="margin-top: 2.5rem;">
          <a href="/get-started" class="hp-btn is-cream">Start Your Diagnostic <span class="arrow">→</span></a>
        </div>
        <span class="hp-nda">A mutual confidentiality agreement (NDA) is executed prior to any data intake.</span>
        <p class="hp-final-secondary">Prefer to read the full analysis first? <a href="/profit-leaks">Read the Profit Leaks page →</a></p>
      </div>
    </section>

    {/* Leak Meter — fixed-positioned, but scoped under .hp-page so its
        hp-meter / hp-meter-tab selectors match. client:load because the
        epoch/session logic must init on mount, not on scroll. */}
    <LeakMeter client:load />
  </div>
</BaseLayout>

<script>
  /* Final CTA live numbers — listens for LeakMeter's bl:leaktick event
     and updates the static <span> placeholders. No React hydration
     for this section. The meter dispatches bl:leaktick every 250ms
     regardless of dismissed state (the tick effect stays active;
     dismissal only swaps the rendered tab vs. aside), so these
     numbers stay accurate even when the meter is collapsed. */
  interface LeakTickDetail {
    value: number
    daysToBreakEven: number
    tier: 'A' | 'B' | 'C'
  }

  const leakEl = document.getElementById('final-leak')
  const daysEl = document.getElementById('final-days')
  const fmtUSD = (n: number) => '$' + Math.floor(n).toLocaleString('en-US')

  window.addEventListener('bl:leaktick', (e) => {
    const d = (e as CustomEvent<LeakTickDetail>).detail
    if (!d) return
    if (leakEl) leakEl.textContent = fmtUSD(d.value)
    if (daysEl) daysEl.textContent = 'about ' + d.daysToBreakEven + ' days'
  })
</script>
