---
import BarePageLayout from '../layouts/BarePageLayout.astro'
---
<BarePageLayout
  title="Unsubscribed | BaxterLabs Advisory"
  description="You've been unsubscribed from BaxterLabs Advisory emails."
  noindex={true}
>
  <div class="min-h-screen bg-ivory flex flex-col">
    <header class="bg-crimson">
      <div class="flex items-center justify-center py-5">
        <a href="/">
          <img src="/images/baxterlabs-logo-white-text.png" alt="BaxterLabs Advisory" class="h-[83px] w-auto" />
        </a>
      </div>
    </header>
    <div class="h-[3px] bg-gold"></div>

    <div class="flex-1 flex items-center justify-center px-4 py-12">
      <div class="text-center max-w-lg">
        <h1 class="font-display text-3xl sm:text-4xl font-bold text-crimson mb-5">
          You've been unsubscribed.
        </h1>
        <p class="text-charcoal text-base leading-relaxed mb-8">
          You won't receive any further emails from BaxterLabs Advisory. If you ever want to pick the conversation back up, a reply to any of our earlier emails lands directly with George.
        </p>
        <a
          href="/"
          class="inline-block px-6 py-3 bg-crimson text-white font-semibold rounded-lg hover:bg-crimson/90 text-sm"
        >
          Back to Home
        </a>
      </div>
    </div>

    <footer class="bg-teal py-6 px-4 text-center">
      <p class="text-white/70 text-xs">&copy; 2026 BaxterLabs Advisory</p>
    </footer>
  </div>
</BarePageLayout>
