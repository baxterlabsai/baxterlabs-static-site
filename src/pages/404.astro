---
import BarePageLayout from '../layouts/BarePageLayout.astro'
---
<BarePageLayout
  title="Page Not Found | BaxterLabs Advisory"
  description="The page you're looking for doesn't exist or has been moved."
>
  <div class="min-h-screen bg-ivory flex flex-col">
    <header class="bg-crimson">
      <div class="flex items-center justify-center py-5">
        <a href="/">
          <img src="/images/baxterlabs-logo-white-text.png" alt="BaxterLabs Advisory" class="h-[83px] w-auto" />
        </a>
      </div>
    </header>
    <div class="h-[3px] bg-gold"></div>

    <div class="flex-1 flex items-center justify-center px-4">
      <div class="text-center max-w-md">
        <p class="text-6xl font-display font-bold text-crimson mb-4">404</p>
        <h1 class="font-display text-2xl font-bold text-charcoal mb-3">Page Not Found</h1>
        <p class="text-gray-warm text-sm mb-8">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/"
            class="px-6 py-3 bg-crimson text-white font-semibold rounded-lg hover:bg-crimson/90 text-sm"
          >
            Back to Home
          </a>
          <a
            href="/dashboard"
            class="px-6 py-3 bg-teal text-white font-semibold rounded-lg hover:bg-teal/90 text-sm"
          >
            Partner Dashboard
          </a>
        </div>
      </div>
    </div>

    <footer class="bg-teal py-6 px-4 text-center">
      <p class="text-white/70 text-xs">&copy; 2026 BaxterLabs Advisory</p>
    </footer>
  </div>
</BarePageLayout>
