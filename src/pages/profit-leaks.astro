  <script is:inline>
    (function () {
      var TIER_DATA = {
        A: { hero: '$200K to $700K', heroShort: '$200K &ndash; $700K', L1: '$50K &ndash; $200K', L2: '$30K &ndash; $150K', L3: '$30K &ndash; $120K', L4: '$15K &ndash; $60K', L5: '$60K &ndash; $200K', roi: '16x' },
        B: { hero: '$450K to $1.5M', heroShort: '$450K &ndash; $1.5M', L1: '$150K &ndash; $500K', L2: '$100K &ndash; $400K', L3: '$60K &ndash; $250K', L4: '$30K &ndash; $100K', L5: '$120K &ndash; $450K', roi: '36x' },
        C: { hero: '$1M to $3.5M', heroShort: '$1M &ndash; $3.5M', L1: '$400K &ndash; $1.5M', L2: '$250K &ndash; $800K', L3: '$150K &ndash; $500K', L4: '$60K &ndash; $250K', L5: '$250K &ndash; $850K', roi: '80x' }
      };

      function parseHashTier() {
        var h = (window.location.hash || '').toLowerCase();
        var m = h.match(/tier=([abc])/);
        if (!m) return 'B';
        return m[1].toUpperCase();
      }

      function applyTier(t) {
        if (!TIER_DATA[t]) t = 'B';
        var d = TIER_DATA[t];
        document.querySelectorAll('[data-tier-hero]').forEach(function (el) { el.innerHTML = d.hero; });
        document.querySelectorAll('[data-tier-hero-2]').forEach(function (el) { el.innerHTML = d.heroShort; });
        document.querySelectorAll('[data-tier-hero-3]').forEach(function (el) { el.innerHTML = d.hero; });
        document.querySelectorAll('[data-tier-l1]').forEach(function (el) { el.innerHTML = d.L1; });
        document.querySelectorAll('[data-tier-l2]').forEach(function (el) { el.innerHTML = d.L2; });
        document.querySelectorAll('[data-tier-l3]').forEach(function (el) { el.innerHTML = d.L3; });
        document.querySelectorAll('[data-tier-l4]').forEach(function (el) { el.innerHTML = d.L4; });
        document.querySelectorAll('[data-tier-l5]').forEach(function (el) { el.innerHTML = d.L5; });
        document.querySelectorAll('[data-tier-roi]').forEach(function (el) { el.textContent = d.roi; });
        document.querySelectorAll('.pl-size-btn').forEach(function (b) {
          var on = b.getAttribute('data-tier') === t;
          b.classList.toggle('active', on);
          b.setAttribute('aria-checked', on ? 'true' : 'false');
        });
      }

      function setHashTier(t) {
        var h = 'tier=' + t.toLowerCase();
        if (history && typeof history.replaceState === 'function') {
          history.replaceState(null, '', '#' + h);
        } else {
          window.location.hash = h;
        }
      }

      document.querySelectorAll('.pl-size-btn').forEach(function (b) {
        b.addEventListener('click', function () {
          var t = b.getAttribute('data-tier');
          if (!t || !TIER_DATA[t]) return;
          setHashTier(t);
          applyTier(t);
        });
      });

      window.addEventListener('hashchange', function () {
        applyTier(parseHashTier());
      });

      applyTier(parseHashTier());
    })();
  </script>
</BaseLayout>
