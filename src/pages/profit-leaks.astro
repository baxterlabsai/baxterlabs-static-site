const title = 'The Profit Leaks Hiding in Every Firm | BaxterLabs'
const description = "The leak categories where margin escapes in $5M to $50M professional service firms: the mechanisms, the structural cause, and what a finished diagnostic looks like."
const canonical = 'https://baxterlabs.ai/profit-leaks'

// TODO: replace with custom dark-dossier og:image PNG (referenced in brief Section 10).
// Using the default site OG as a placeholder until design delivers the asset.
const ogImage = '/images/baxterlabs-og.png'

const datePublished = '2026-04-23'

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'The Profit Leaks Hiding in Every Firm.',
  description,
  author: {
    '@type': 'Person',
    name: 'George DeVries',
  },
  datePublished,
  publisher: {
    '@type': 'Organization',
    name: 'BaxterLabs Advisory',
    logo: {
