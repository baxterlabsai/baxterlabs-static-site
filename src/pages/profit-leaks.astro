import BaseLayout from '../layouts/BaseLayout.astro'
import '../components/profit-leaks/pillar.css'
import MarginErosionChart from '../components/profit-leaks/MarginErosionChart'
import FragilityLoop from '../components/profit-leaks/FragilityLoop'
