  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'BaxterLabs Advisory',
  url: 'https://baxterlabs.ai/',
  logo: 'https://baxterlabs.ai/images/baxterlabs-logo.png',
  description: 'Forensic profit-leak diagnostics for $5M to $50M professional service firms.',
