# BaxterLabs Marketing Site — Environment Variables
# =================================================
# All env vars are loaded from ~/Projects/master.env
# This file exists for documentation purposes only.

# ── Frontend build (Vite) ──
# VITE_API_URL=https://api.baxterlabs.ai
#   Used by:
#     - src/pages/GetStarted.tsx  → POST /api/pipeline/website-intake
#     - src/pages/BlogIndex.tsx   → GET  /api/public/blog
#     - src/pages/BlogPost.tsx    → GET  /api/public/blog/{slug}
